{
  "schema_version": 1,
  "posting": {
    "days_limit": 365,
    "max_attempts": 5,
    "max_post_chars": 300,
    "hashtags": [
      "#jokes",
      "#dadjoke",
      "#funny"
    ]
  },
  "follow_fellows": {
    "per_tag_limit": 12,
    "global_follow_limit": 150,
    "search_limit": 100,
    "hashtags": [
      "followback",
      "dadjoke",
      "dadjokes",
      "joke",
      "jokes",
      "humour",
      "humor",
      "humoursky",
      "humorsky",
      "jokesky",
      "momjokes",
      "mumjokes",
      "groan",
      "puns",
      "pun",
      "punny",
      "divertido",
      "funny"
    ]
  },
  "unfollow": {
    "max_actions": 200,
    "batch_size": 50,
    "batch_pause_seconds": 60.0,
    "default_ignorable_handles": [
      "theonion.bsky.social",
      "groandeck.bsky.social",
      "nocontextbritss.bsky.social",
      "dehler55.bsky.social"
    ]
  },
  "reports": {
    "max_pages": 3,
    "page_limit": 100
  },
  "workflow_schedules": {
    "bluesky_post_joke": "0 0,4,8,12,16,20 * * *",
    "bluesky_follows_and_likes": "0 */2 * * *",
    "bluesky_follow_fellows": "0 0 * * 3,5",
    "bluesky_unfollow": "0 12 1 */3 *",
    "bluesky_process_reports": "*/30 * * * *",
    "bluesky_validate_unfollow_ignore": "0 9 1 * *"
  }
}
