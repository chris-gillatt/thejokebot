# Copy this file to .env and set values locally.
# Do not commit real secrets.
# Keep values quoted so special characters are parsed safely.
# If a value contains a single quote, wrap it in double quotes instead.

BLUESKY_USERNAME=''
BLUESKY_PASSWORD=''
API_NINJAS_API_KEY=''
BLUESKY_DRY_RUN='false'
BLUESKY_ACTION_DELAY_SECONDS='0'
BLUESKY_NETWORK_RETRY_ATTEMPTS='3'
BLUESKY_NETWORK_RETRY_DELAY_SECONDS='1'
BLUESKY_NETWORK_RETRY_BACKOFF_FACTOR='2'
BLUESKY_UNFOLLOW_MAX_ACTIONS='200'
BLUESKY_UNFOLLOW_BATCH_SIZE='50'
BLUESKY_UNFOLLOW_BATCH_PAUSE_SECONDS='60'
# Comma-separated fully-qualified handles to never unfollow (e.g. 'handle1.bsky.social,handle2.bsky.social').
BLUESKY_UNFOLLOW_IGNORE=''
# Starter-pack/list protection is configured in resources/jokebot_starter_pack.json.
# When that config is enabled and source_list_uri is set, list members are
# automatically protected from unfollowing.

# Joke provider selection.
# Leave blank (or set to 'auto') to alternate between the primary providers
# and only use backup providers if the primaries fail.
# Set to a provider name to force that provider every run.
# Allowed values: '' | 'auto' | 'icanhazdadjoke' | 'jokeapi' | 'groandeck' | 'syrsly' | 'api_ninjas' | 'jokebot_jokebook'
BLUESKY_JOKE_PROVIDER=''
